# Smith Asset Group — AI Agent environment variables
# Copy this file to .env and fill in your real keys (never commit .env to git)

# Anthropic API key (from console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Notion integration token (from notion.so/my-integrations)
# The integration must be added to all 4 databases in the Notion workspace
NOTION_API_KEY=secret_...
