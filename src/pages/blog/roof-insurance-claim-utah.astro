  <!-- Hero -->
  <div class="blog-hero">
    <div class="container">
      <span class="blog-badge">Insurance Guide · Utah Homeowners</span>
      <h1>How to File a Roof Insurance Claim in Utah — Step-by-Step Guide</h1>
      <p class="blog-meta">By Sandy Roofing Pros &nbsp;·&nbsp; Updated May 2026 &nbsp;·&nbsp; 10 min read</p>
    </div>
