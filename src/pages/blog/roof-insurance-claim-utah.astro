const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long do I have to file a roof insurance claim in Utah?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Utah homeowners insurance policies require you to file a storm damage claim within 12 months of the damage event. Some policies have shorter windows. Check your policy's 'duties after loss' section for your specific deadline. Filing late is one of the most common reasons claims are denied."
      }
    },
    {
      "@type": "Question",
      "name": "What documentation do I need for a roof insurance claim in Utah?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You'll need photos of the damage (ground-level and roof-level), the date of the storm or event that caused the damage, your policy number, and ideally a contractor's written damage assessment with measurements. Weather data showing the storm event in your area also helps establish causation."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between ACV and RCV in a roof insurance claim?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ACV (Actual Cash Value) pays the depreciated value of your damaged roof — what it was worth at its current age, not what it costs to replace it. RCV (Replacement Cost Value) pays the full cost of replacement. Most Utah policies include RCV coverage, but pay ACV first, then release the withheld depreciation (called 'recoverable depreciation') once the work is completed and documented."
      }
    },
    {
      "@type": "Question",
      "name": "Can an insurance company deny a roof claim in Utah?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Common denial reasons include: damage attributed to wear and tear rather than a covered storm event, missing the filing deadline, insufficient documentation, or a policy exclusion. If your claim is denied, you can dispute it — starting with a written request for the specific denial reason and then potentially invoking your policy's appraisal or dispute resolution process."
      }
    }
  ]
