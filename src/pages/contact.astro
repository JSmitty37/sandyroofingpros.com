---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";
---

<BaseLayout
  title="Contact Us | Sandy Roofing Pros — Sandy, UT"
  description="Contact Sandy Roofing Pros for emergency roof leak repair or storm damage help in Sandy, Utah and Salt Lake County. Call now or fill out our free estimate form."
  canonicalUrl="/contact"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <h1>Contact Sandy Roofing Pros</h1>
      <p>
        Roof emergency? Call — don't fill out a form. If it can wait,
        the form works fine and someone will follow up same day.
      </p>
    </div>
  </section>

  <!-- Contact Split -->
  <section class="section">
    <div class="container">
      <div class="contact-split">

        <!-- Left: Contact Info -->
        <div class="contact-info">
          <h2>Call First. Form Second.</h2>
          <p>
            If water is coming in right now, don't wait for a callback.
            <strong>The number below goes to someone who can get a roofer
            to your door.</strong> If it's not an emergency, the form works fine.
          </p>

          <a href={phoneHref} class="contact-info__phone" aria-label="Call Sandy Roofing Pros">
            📞 {phone}
          </a>

          <p>
            <strong>Available 24/7</strong> — including nights, weekends, and holidays
            for emergency roof situations.
          </p>

          <div style="margin-top:1.5rem;">
            <h3 style="margin-bottom:0.5rem;">What Happens When You Call</h3>
            <ol style="padding-left:1.25rem; color:#64748B; font-size:0.95rem; line-height:2;">
              <li>Tell us what's happening and where you are</li>
              <li>We get the right roofer on the phone with you</li>
              <li>They confirm they can get out — usually same day</li>
              <li>You get a written estimate before anything starts</li>
            </ol>
          </div>

          <div class="contact-info__note">
            <strong>Not an emergency?</strong> No problem. Use the form to describe
            your situation and a contractor will follow up with you during normal
            business hours.
          </div>

          <div style="margin-top:2rem;">
            <h3 style="margin-bottom:0.75rem;">Service Area</h3>
            <p style="color:#64748B; font-size:0.9rem;">
              We serve homeowners throughout <strong>Salt Lake County, Utah</strong> — including
              Sandy, Draper, South Jordan, Murray, Midvale, West Jordan, and Salt Lake City.
            </p>
            <a href="/service-area" style="font-size:0.9rem;">View Full Service Area →</a>
          </div>
        </div>

        <!-- Right: Lead Form -->
        <div>
          <LeadForm
            title="Send Us Your Information"
            subtitle="A licensed contractor will follow up with you quickly — free of charge."
            elementId="contact-form"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Emergency CTA -->
  <section class="cta-strip">
    <div class="container">
      <h2>Water Coming In? Don't Google It. Call.</h2>
      <p>Same-day help is available throughout Salt Lake County, day or night.</p>
      <div class="cta-strip__actions">
        <a href={phoneHref} class="btn btn--accent btn--lg">
          📞 Call {phone} — Available 24/7
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
