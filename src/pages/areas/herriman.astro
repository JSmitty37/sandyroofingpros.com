---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";

const localServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Repair in Herriman, UT",
  "description": "Emergency roof repair, storm damage restoration, hail damage repair, and roof inspections serving Herriman, Utah. Same-day response. Free estimates.",
  "areaServed": {
    "@type": "City",
    "name": "Herriman",
    "containedInPlace": {
      "@type": "State",
      "name": "Utah",
      "sameAs": "https://en.wikipedia.org/wiki/Utah"
    },
    "sameAs": "https://en.wikipedia.org/wiki/Herriman,_Utah"
  },
  "provider": {
    "@type": "RoofingContractor",
    "name": "Sandy Roofing Pros",
    "url": "https://sandyroofingpros.com",
    "telephone": "+18015147004"
  },
  "serviceType": ["Emergency Roof Repair", "Storm Damage Repair", "Hail Damage Repair", "Roof Inspection", "Insurance Claim Assistance"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sandyroofingpros.com" },
    { "@type": "ListItem", "position": 2, "name": "Service Area", "item": "https://sandyroofingpros.com/service-area" },
    { "@type": "ListItem", "position": 3, "name": "Herriman, UT", "item": "https://sandyroofingpros.com/areas/herriman" }
  ]
};
---

<BaseLayout
  title="Roof Repair in Herriman, UT | Sandy Roofing Pros — Emergency & Storm Damage"
  description="Emergency roof repair and storm damage restoration in Herriman, Utah. Licensed local contractors serving all Herriman neighborhoods. Free estimates — ZIP 84096."
  canonicalUrl="/areas/herriman"
>

  <script type="application/ld+json" set:html={JSON.stringify(localServiceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="area-hero" style="background-image: url('/images/hero-bg.jpg');">
    <div class="container">
      <span class="area-badge">📍 Serving Herriman, UT — 84096</span>
      <h1>Roof Repair in Herriman, UT — Emergency Service &amp; Storm Damage</h1>
      <p>
        Herriman's rapid growth over the last decade means thousands of newer homes — and newer
        doesn't always mean problem-free. Hail exposure from storms tracking off the Oquirrh
        Mountains, combined with new construction roofing defects that show up after the first few
        winters, keeps Herriman homeowners busy. When you need a roofer who responds the same day,
        we're here.
      </p>
      <div class="hero__ctas">
        <a href={phoneHref} class="btn btn--primary btn--lg">📞 Call Now for a Free Estimate</a>
        <a href="#get-estimate" class="btn btn--outline btn--lg">Get Instant Help Online</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="container">
      <ul class="trust-bar__list">
        <li class="trust-bar__item"><span class="trust-bar__icon">⚡</span><span>Same-Day Response</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">✅</span><span>Licensed Utah Contractors</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">💲</span><span>Free Estimates</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">🛡️</span><span>Insurance Claims Assisted</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">📍</span><span>Herriman, UT 84096</span></li>
      </ul>
    </div>
  </div>

  <!-- Local Context -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Herriman Roofing Challenges</span>
        <h2>New Homes, Real Roofing Problems</h2>
        <p>
          Herriman's growth has been fast. That has roofing implications that many newer homeowners
          haven't had to deal with yet.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🏗️</div>
            <h3>New Construction Defects</h3>
            <p>
              When builders are moving fast, roofing installation quality suffers. Improper flashing
              around chimneys and skylights, inadequate underlayment laps, and missed nail zones
              in shingles often don't show up until after the builder warranty expires — typically
              after the first 2–5 winters. If your Herriman home is 3–8 years old, an inspection
              is worth doing before any warranty claims expire.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">⛈️</div>
            <h3>Oquirrh Mountain Storm Exposure</h3>
            <p>
              Storms moving east off the Oquirrh Mountains can hit Herriman with significant
              hail before tracking toward Sandy and South Jordan. The western-facing exposure
              of many Herriman subdivisions means storms arriving from the Great Salt Lake
              corridor hit the roof face-on.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">☀️</div>
            <h3>High-Altitude UV Degradation</h3>
            <p>
              Herriman sits at roughly 5,000 feet elevation — noticeably higher than the valley
              floor. Higher UV intensity accelerates shingle aging on south and west-facing roof
              sections. Roofs in Herriman often show aging patterns faster than comparable homes
              in Murray or Midvale.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">What We Do in Herriman</span>
        <h2>Roofing Services for Herriman Homeowners</h2>
      </div>

      <ul class="why-list">
        <li class="why-item">
          <div class="why-item__icon">🚨</div>
          <div class="why-item__text">
            <h3>Emergency Leak Repair</h3>
            <p>Active leak anywhere in Herriman? Same-day response available. We'll get a licensed contractor to your door to stop the damage and assess the cause — same day.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🌩️</div>
          <div class="why-item__text">
            <h3>Storm &amp; Hail Damage</h3>
            <p>Free post-storm inspection with full damage documentation. We work with your insurance adjuster directly to ensure the full scope of damage is captured and covered.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🔍</div>
          <div class="why-item__text">
            <h3>New Construction Warranty Inspections</h3>
            <p>If your Herriman home is approaching the end of its builder warranty period, a roof inspection now can identify installation defects while you can still make a warranty claim.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">📋</div>
          <div class="why-item__text">
            <h3>Insurance Claim Support</h3>
            <p>We document storm damage the way insurance adjusters need to see it — photos, measurements, written assessment. Our contractors will be present during your adjuster visit if needed.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Lead Form -->
  <section class="section" id="get-estimate">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Free Estimate</span>
        <h2>Get a Herriman Roofer Out Fast — It's Free</h2>
        <p>Fill out the form and a licensed contractor serving Herriman will follow up quickly.</p>
      </div>
      <LeadForm
        title="Request a Free Estimate in Herriman, UT"
        subtitle="A licensed local roofing contractor will call you back — usually within the hour."
        elementId="herriman-form"
      />
    </div>
  </section>

  <!-- Nearby Areas -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Also Serving</span>
        <h2>We Cover All of Southwest Salt Lake County</h2>
      </div>
      <p style="max-width:720px; margin: 0 auto; text-align:center; color:#374151;">
        In addition to Herriman, we serve <a href="/areas/riverton">Riverton</a>,
        <a href="/areas/south-jordan">South Jordan</a>, <a href="/areas/west-jordan">West Jordan</a>,
        <a href="/areas/sandy">Sandy</a>, <a href="/areas/draper">Draper</a>, and all of
        Salt Lake County. Same-day response throughout the service area.
      </p>
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>Herriman Roof Emergency? Call Now.</h2>
      <p>Same-day response throughout Herriman (84096) and all of southwest Salt Lake County.</p>
      <div class="cta-strip__actions">
        <a href={phoneHref} class="btn btn--accent btn--lg">📞 {phone} — Available 24/7</a>
      </div>
    </div>
  </section>

</BaseLayout>
