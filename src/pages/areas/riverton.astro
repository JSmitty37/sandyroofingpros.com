---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";

const localServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Repair in Riverton, UT",
  "description": "Emergency roof repair, storm damage restoration, hail damage repair, and roof inspections serving Riverton, Utah. Same-day response. Free estimates.",
  "areaServed": {
    "@type": "City",
    "name": "Riverton",
    "containedInPlace": {
      "@type": "State",
      "name": "Utah",
      "sameAs": "https://en.wikipedia.org/wiki/Utah"
    },
    "sameAs": "https://en.wikipedia.org/wiki/Riverton,_Utah"
  },
  "provider": {
    "@type": "RoofingContractor",
    "name": "Sandy Roofing Pros",
    "url": "https://sandyroofingpros.com",
    "telephone": "+18015147004"
  },
  "serviceType": ["Emergency Roof Repair", "Storm Damage Repair", "Hail Damage Repair", "Roof Inspection", "Insurance Claim Assistance"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sandyroofingpros.com" },
    { "@type": "ListItem", "position": 2, "name": "Service Area", "item": "https://sandyroofingpros.com/service-area" },
    { "@type": "ListItem", "position": 3, "name": "Riverton, UT", "item": "https://sandyroofingpros.com/areas/riverton" }
  ]
};
---

<BaseLayout
  title="Roof Repair in Riverton, UT | Sandy Roofing Pros — Emergency & Storm Damage"
  description="Emergency roof repair and storm damage restoration in Riverton, Utah. Licensed local contractors serving all Riverton neighborhoods. Free estimates — ZIP 84065."
  canonicalUrl="/areas/riverton"
>

  <script type="application/ld+json" set:html={JSON.stringify(localServiceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="area-hero" style="background-image: url('/images/hero-bg.jpg');">
    <div class="container">
      <span class="area-badge">📍 Serving Riverton, UT — 84065</span>
      <h1>Roof Repair in Riverton, UT — Emergency Service &amp; Storm Damage</h1>
      <p>
        Riverton is one of the fastest-growing cities in Salt Lake County — and its mix of
        established homes along the Jordan River corridor and newer construction near Bangerter
        Highway means a full range of roofing conditions. Storm damage, hail, aging shingles,
        and new construction issues all show up regularly here. When you need a roofer the same day,
        we have licensed contractors ready.
      </p>
      <div class="hero__ctas">
        <a href={phoneHref} class="btn btn--primary btn--lg">📞 Call Now for a Free Estimate</a>
        <a href="#get-estimate" class="btn btn--outline btn--lg">Get Instant Help Online</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="container">
      <ul class="trust-bar__list">
        <li class="trust-bar__item"><span class="trust-bar__icon">⚡</span><span>Same-Day Response</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">✅</span><span>Licensed Utah Contractors</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">💲</span><span>Free Estimates</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">🛡️</span><span>Insurance Claims Assisted</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">📍</span><span>Riverton, UT 84065</span></li>
      </ul>
    </div>
  </div>

  <!-- Local Context -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Riverton Roofing Conditions</span>
        <h2>Two Distinct Housing Eras — Two Sets of Roofing Issues</h2>
        <p>
          Riverton's housing stock spans from 1970s and 80s established neighborhoods near 12600
          South to brand-new construction subdivisions closer to 11400 South and Bangerter.
          Each era has its own characteristic roofing challenges.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🏚️</div>
            <h3>Older Homes: Aging Shingles and Failing Flashing</h3>
            <p>
              Homes in the 30–40 year range are at or past the typical asphalt shingle lifespan
              (25–30 years for 3-tab, 30–40 years for architectural). Many Riverton homeowners
              in these neighborhoods are dealing with granule loss, blistering, and flashing
              failure that creates leaks — often accelerated by Utah's UV intensity.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🏗️</div>
            <h3>Newer Homes: Installation Issues</h3>
            <p>
              Riverton's construction boom produced roofs installed quickly by crews under
              schedule pressure. Post-warranty failures — typically appearing 3–8 years after
              build — include improperly installed flashing around penetrations, inadequate
              valley underlayment, and insufficient starter strip installation.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">⛈️</div>
            <h3>Hail and Storm Exposure</h3>
            <p>
              Riverton sits in a storm corridor between the Oquirrh Mountains and the Wasatch
              Front. Late spring and summer hail events — often moving northeast from Utah
              County — regularly affect Riverton before hitting Sandy. The 84065 ZIP code
              has historically been in the top tier for SLC metro hail frequency.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">What We Do in Riverton</span>
        <h2>Roofing Services for Riverton Homeowners</h2>
      </div>

      <ul class="why-list">
        <li class="why-item">
          <div class="why-item__icon">🚨</div>
          <div class="why-item__text">
            <h3>Emergency Leak Repair</h3>
            <p>Active leak anywhere in Riverton? Same-day response available. We get a licensed contractor to your door fast to contain the damage and identify the source.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🌩️</div>
          <div class="why-item__text">
            <h3>Storm &amp; Hail Damage</h3>
            <p>Free post-storm inspection with complete documentation for your insurance claim. We know the hail patterns that affect Riverton and document damage correctly.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🔧</div>
          <div class="why-item__text">
            <h3>Flashing and Leak Repairs</h3>
            <p>Most leaks in Riverton homes originate at flashing failures — around chimneys, skylights, and roof valleys. Our contractors identify the actual entry point, not just the symptom.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🔍</div>
          <div class="why-item__text">
            <h3>Pre-Sale &amp; Pre-Purchase Inspections</h3>
            <p>Riverton is a high-turnover real estate market. Get a roof inspection before listing or before closing — from a contractor who knows the specific issues in 84065 homes.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">📋</div>
          <div class="why-item__text">
            <h3>Insurance Claim Support</h3>
            <p>We document storm damage for insurance purposes throughout Riverton. Adjusters, documentation, estimates — we handle it all so you get the full coverage you're owed.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Lead Form -->
  <section class="section" id="get-estimate">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Free Estimate</span>
        <h2>Get a Riverton Roofer Out Fast — It's Free</h2>
        <p>Fill out the form and a licensed contractor serving Riverton will follow up quickly.</p>
      </div>
      <LeadForm
        title="Request a Free Estimate in Riverton, UT"
        subtitle="A licensed local roofing contractor will call you back — usually within the hour."
        elementId="riverton-form"
      />
    </div>
  </section>

  <!-- Nearby Areas -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Also Serving</span>
        <h2>Serving All of South Salt Lake County</h2>
      </div>
      <p style="max-width:720px; margin: 0 auto; text-align:center; color:#374151;">
        We serve Riverton and the surrounding communities including <a href="/areas/herriman">Herriman</a>,
        <a href="/areas/south-jordan">South Jordan</a>, <a href="/areas/west-jordan">West Jordan</a>,
        <a href="/areas/sandy">Sandy</a>, and <a href="/areas/draper">Draper</a>.
        Same-day response available throughout all of Salt Lake County.
      </p>
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>Riverton Roof Emergency? Call Now.</h2>
      <p>Same-day response throughout Riverton (84065) and all of south Salt Lake County.</p>
      <div class="cta-strip__actions">
        <a href={phoneHref} class="btn btn--accent btn--lg">📞 {phone} — Available 24/7</a>
      </div>
    </div>
  </section>

</BaseLayout>
