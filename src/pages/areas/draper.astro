---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";

const localServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Repair in Draper, UT",
  "description": "Emergency roof repair, storm damage restoration, and roof inspections serving Draper, Utah. Same-day response. Free estimates.",
  "areaServed": {
    "@type": "City",
    "name": "Draper",
    "containedInPlace": {
      "@type": "State",
      "name": "Utah",
      "sameAs": "https://en.wikipedia.org/wiki/Utah"
    },
    "sameAs": "https://en.wikipedia.org/wiki/Draper,_Utah"
  },
  "provider": {
    "@type": "RoofingContractor",
    "name": "Sandy Roofing Pros",
    "url": "https://sandyroofingpros.com",
    "telephone": "+18015147004"
  },
  "serviceType": ["Emergency Roof Repair", "Storm Damage Repair", "Hail Damage Repair", "Roof Inspection"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sandyroofingpros.com" },
    { "@type": "ListItem", "position": 2, "name": "Service Area", "item": "https://sandyroofingpros.com/service-area" },
    { "@type": "ListItem", "position": 3, "name": "Draper, UT", "item": "https://sandyroofingpros.com/areas/draper" }
  ]
};
---

<BaseLayout
  title="Roof Repair in Draper, UT | Sandy Roofing Pros — Emergency & Storm Damage"
  description="Emergency roof repair and storm damage restoration in Draper, Utah. Licensed local contractors serving Suncrest, Bangerter Highway, and all Draper neighborhoods. Free estimates."
  canonicalUrl="/areas/draper"
>

  <!-- Local Service + Breadcrumb structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(localServiceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="area-hero" style="background-image: url('/images/hero-bg.jpg');">
    <div class="container">
      <span class="area-badge">📍 Serving Draper, UT — 84020</span>
      <h1>Roof Repair in Draper, UT — Emergency Service &amp; Storm Damage</h1>
      <p>
        Draper takes more hail than most of Salt Lake County. Sitting at the base of the
        Wasatch foothills and exposed to storm cells that build over the Point of the Mountain,
        it's not uncommon for Draper to get hit while the valley floor stays dry.
        If a storm just rolled through your neighborhood, here's what to do.
      </p>
      <div class="hero__ctas">
        <a href={phoneHref} class="btn btn--primary btn--lg">📞 Call Now for a Free Estimate</a>
        <a href="#get-estimate" class="btn btn--outline btn--lg">Get Instant Help Online</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="container">
      <ul class="trust-bar__list">
        <li class="trust-bar__item"><span class="trust-bar__icon">⚡</span><span>Same-Day Response</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">✅</span><span>Licensed Utah Contractors</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">💲</span><span>Free Estimates</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">🛡️</span><span>Insurance Claims Assisted</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">📍</span><span>Draper, UT 84020</span></li>
      </ul>
    </div>
  </div>

  <!-- About Draper Roofing -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Why Draper Is Different</span>
        <h2>Draper's Roofs Take a Specific Kind of Beating</h2>
        <p>
          Elevation, sun exposure, and storm positioning make Draper one of the toughest
          environments for residential roofing in the county.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">⛈️</div>
            <h3>Point of the Mountain Hail</h3>
            <p>
              Summer storm cells frequently stall over the southern end of the valley near
              the Point of the Mountain before tracking northeast. Draper and Suncrest
              neighborhoods sit directly in that path. Large hail events that miss Sandy
              entirely can hit Draper hard.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">☀️</div>
            <h3>South-Facing UV Exposure</h3>
            <p>
              Draper's hillside and foothill properties have significant south-facing roof
              sections that bake in direct sun at elevation. Shingles on these faces
              typically age faster than north or east-facing sections — often 3 to 5 years
              ahead of schedule.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🏗️</div>
            <h3>New Construction Risk</h3>
            <p>
              Draper's rapid growth means a lot of roofs installed in the last 10 years.
              New doesn't mean problem-free — flashing failures and improper installation
              often show up after the first few winters. Hail damage doesn't discriminate
              by age of the roof.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">What We Do in Draper</span>
        <h2>Roofing Services for Draper Homeowners</h2>
      </div>

      <ul class="why-list">
        <li class="why-item">
          <div class="why-item__icon">🚨</div>
          <div class="why-item__text">
            <h3>Emergency Leak Repair</h3>
            <p>Active leak in your Draper home? Same-day response available. We dispatch a licensed contractor to stop the damage before it spreads.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🌩️</div>
          <div class="why-item__text">
            <h3>Storm &amp; Hail Damage</h3>
            <p>Post-storm inspection with full documentation for your insurance adjuster. Suncrest, Highland Drive, Bangerter corridor — all covered.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🔍</div>
          <div class="why-item__text">
