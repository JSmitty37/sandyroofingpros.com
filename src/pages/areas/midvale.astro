---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";

const localServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Repair in Midvale, UT",
  "description": "Emergency roof repair, storm damage restoration, and roof inspections serving Midvale, Utah. Same-day response. Free estimates.",
  "areaServed": {
    "@type": "City",
    "name": "Midvale",
    "containedInPlace": {
      "@type": "State",
      "name": "Utah",
      "sameAs": "https://en.wikipedia.org/wiki/Utah"
    },
    "sameAs": "https://en.wikipedia.org/wiki/Midvale,_Utah"
  },
  "provider": {
    "@type": "RoofingContractor",
    "name": "Sandy Roofing Pros",
    "url": "https://sandyroofingpros.com",
    "telephone": "+18015147004"
  },
  "serviceType": ["Emergency Roof Repair", "Storm Damage Repair", "Hail Damage Repair", "Roof Inspection"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sandyroofingpros.com" },
    { "@type": "ListItem", "position": 2, "name": "Service Area", "item": "https://sandyroofingpros.com/service-area" },
    { "@type": "ListItem", "position": 3, "name": "Midvale, UT", "item": "https://sandyroofingpros.com/areas/midvale" }
  ]
};
---

<BaseLayout
  title="Roof Repair in Midvale, UT | Sandy Roofing Pros — Emergency & Storm Damage"
  description="Emergency roof repair and storm damage restoration in Midvale, Utah. Licensed local contractors serving all Midvale neighborhoods. Same-day response. Free estimates."
  canonicalUrl="/areas/midvale"
>

  <script type="application/ld+json" set:html={JSON.stringify(localServiceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="area-hero" style="background-image: url('/images/hero-bg.jpg');">
    <div class="container">
      <span class="area-badge">📍 Serving Midvale, UT — 84047</span>
      <h1>Roof Repair in Midvale, UT — Emergency Service &amp; Storm Damage</h1>
      <p>
        Midvale sits between Sandy and Murray — right in the middle of Salt Lake County's
        storm corridor. With a mix of homes built across several decades, many Midvale
        roofs are approaching or past their service life just as storm seasons
        are becoming more severe. When something goes wrong, it goes wrong fast.
      </p>
      <div class="hero__ctas">
        <a href={phoneHref} class="btn btn--primary btn--lg">📞 Call Now for a Free Estimate</a>
        <a href="#get-estimate" class="btn btn--outline btn--lg">Get Instant Help Online</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="container">
      <ul class="trust-bar__list">
        <li class="trust-bar__item"><span class="trust-bar__icon">⚡</span><span>Same-Day Response</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">✅</span><span>Licensed Utah Contractors</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">💲</span><span>Free Estimates</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">🛡️</span><span>Insurance Claims Assisted</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">📍</span><span>Midvale, UT 84047</span></li>
      </ul>
    </div>
  </div>

  <!-- About Midvale Roofing -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Why Midvale Is Different</span>
        <h2>What Midvale Homeowners Need to Know About Their Roofs</h2>
        <p>
          Location, elevation, and housing age combine to make Midvale a high-risk area
          for roof failure — especially after storms.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🌧️</div>
            <h3>Storm Corridor Positioning</h3>
            <p>
              Midvale is positioned directly between the Wasatch Front and the valley floor,
              which means storm cells tracking north from Utah County hit Midvale before
              reaching Murray or Salt Lake. This makes Midvale one of the most hail-exposed
              cities in the county during peak storm season (April through August).
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🏚️</div>
            <h3>Mixed-Age Housing Stock</h3>
            <p>
              Midvale has homes ranging from 1940s bungalows to 2000s subdivisions — and
              everything in between. Older homes often have original sheathing and
              flashing that wasn't designed for today's weather, while newer homes
              can hide installation defects that don't show up until their first major storm.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">❄️</div>
            <h3>Freeze-Thaw Cycles</h3>
            <p>
              Midvale's elevation creates significant freeze-thaw cycling through
              winter and early spring. Water that gets under shingles expands on freezing —
              gradually lifting and cracking shingles with each cycle. By spring, what
              looked like a small problem in November can be a full section failure.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">What We Do in Midvale</span>
        <h2>Roofing Services for Midvale Homeowners</h2>
      </div>

      <ul class="why-list">
        <li class="why-item">
          <div class="why-item__icon">🚨</div>
          <div class="why-item__text">
            <h3>Emergency Leak Repair</h3>
            <p>Active leak in your Midvale home? Same-day response available. A licensed contractor will be dispatched to stop the damage and protect your home's interior.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🌩️</div>
          <div class="why-item__text">
            <h3>Storm &amp; Hail Damage</h3>
            <p>After a storm rolls through, don't wait. Hail damage that isn't documented and repaired quickly leads to denied insurance claims and accelerated roof failure.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🔍</div>
          <div class="why-item__text">
            <h3>Roof Inspections</h3>
            <p>Whether you're buying, selling, or just past due for a checkup, our contractors assess Midvale roofs with an eye for the specific failure modes common to this area.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">📋</div>
          <div class="why-item__text">
            <h3>Insurance Claim Support</h3>
            <p>We document storm damage properly so your adjuster has everything they need. Midvale homeowners who work with us get claims processed faster and with fewer disputes.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Lead Form -->
  <section class="section" id="get-estimate">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Free Estimate</span>
        <h2>Get a Midvale Roofer Out Fast — It's Free</h2>
        <p>Fill out the form and a licensed contractor serving Midvale will follow up quickly.</p>
      </div>
      <LeadForm
        title="Request a Free Estimate in Midvale, UT"
        subtitle="A licensed local roofing contractor will call you back — usually within the hour."
        elementId="midvale-form"
      />
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>Midvale Roof Emergency? Call Now.</h2>
      <p>Same-day response available throughout Midvale and Salt Lake County.</p>
      <div class="cta-strip__actions">
        <a href={phoneHref} class="btn btn--accent btn--lg">📞 {phone} — Available 24/7</a>
      </div>
    </div>
  </section>

</BaseLayout>
