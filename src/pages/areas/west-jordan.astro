---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";

const localServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Repair in West Jordan, UT",
  "description": "Emergency roof repair, storm damage restoration, and roof inspections serving West Jordan, Utah. Same-day response. Free estimates.",
  "areaServed": {
    "@type": "City",
    "name": "West Jordan",
    "containedInPlace": {
      "@type": "State",
      "name": "Utah",
      "sameAs": "https://en.wikipedia.org/wiki/Utah"
    },
    "sameAs": "https://en.wikipedia.org/wiki/West_Jordan,_Utah"
  },
  "provider": {
    "@type": "RoofingContractor",
    "name": "Sandy Roofing Pros",
    "url": "https://sandyroofingpros.com",
    "telephone": "+18015147004"
  },
  "serviceType": ["Emergency Roof Repair", "Storm Damage Repair", "Hail Damage Repair", "Roof Inspection"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sandyroofingpros.com" },
    { "@type": "ListItem", "position": 2, "name": "Service Area", "item": "https://sandyroofingpros.com/service-area" },
    { "@type": "ListItem", "position": 3, "name": "West Jordan, UT", "item": "https://sandyroofingpros.com/areas/west-jordan" }
  ]
};
---

<BaseLayout
  title="Roof Repair in West Jordan, UT | Sandy Roofing Pros — Emergency & Storm Damage"
  description="Emergency roof repair and storm damage restoration in West Jordan, Utah. Licensed local contractors serving Bingham Junction, South Towne, and all West Jordan neighborhoods. Free estimates."
  canonicalUrl="/areas/west-jordan"
>

  <script type="application/ld+json" set:html={JSON.stringify(localServiceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="area-hero" style="background-image: url('/images/hero-bg.jpg');">
    <div class="container">
      <span class="area-badge">📍 Serving West Jordan, UT — 84084 / 84088</span>
      <h1>Roof Repair in West Jordan, UT — Emergency Service &amp; Storm Damage</h1>
      <p>
        West Jordan is one of the largest residential cities in Utah — and one of the most
        storm-exposed. The open terrain west of the Wasatch gives summer hail cells a
        clear run at thousands of homes, and with so much residential density,
        every major storm produces a wave of damage claims across the city.
      </p>
      <div class="hero__ctas">
        <a href={phoneHref} class="btn btn--primary btn--lg">📞 Call Now for a Free Estimate</a>
        <a href="#get-estimate" class="btn btn--outline btn--lg">Get Instant Help Online</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="container">
      <ul class="trust-bar__list">
        <li class="trust-bar__item"><span class="trust-bar__icon">⚡</span><span>Same-Day Response</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">✅</span><span>Licensed Utah Contractors</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">💲</span><span>Free Estimates</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">🛡️</span><span>Insurance Claims Assisted</span></li>
        <li class="trust-bar__item"><span class="trust-bar__icon">📍</span><span>West Jordan, UT 84084</span></li>
      </ul>
    </div>
  </div>

  <!-- About West Jordan Roofing -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Why West Jordan Is Different</span>
        <h2>West Jordan Homeowners Face High Storm Risk</h2>
        <p>
          Size, terrain, and storm patterns make West Jordan one of the highest-volume
          roofing markets in Salt Lake County. Here's why.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🌪️</div>
            <h3>Open Western Exposure</h3>
            <p>
              Unlike cities tucked against the Wasatch, West Jordan's western sections
              have little topographic protection from weather systems moving in from the
              Great Salt Lake and the Nevada desert. Summer microbursts and hail events
              frequently hit the South Towne and Bingham Junction corridors with full
              force before weakening further east.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🏘️</div>
            <h3>High Residential Density</h3>
            <p>
              West Jordan has more single-family homes than almost any city in the county.
              That density means a single hail event can create hundreds of roof damage
              claims simultaneously — and roofing contractors fill up fast. Acting quickly
              after a storm is the difference between getting a same-week repair and
              waiting weeks for an appointment.
            </p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card__body">
            <div class="service-card__icon">🏗️</div>
            <h3>Subdivision-Era Construction</h3>
            <p>
              Much of West Jordan's residential development happened in the 1980s–2000s,
              meaning a large portion of roofs are now 20–40 years old. At that age,
              even moderate hail can cause functional damage that homeowners don't notice
              until they find water stains on their ceiling months later.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">What We Do in West Jordan</span>
        <h2>Roofing Services for West Jordan Homeowners</h2>
      </div>

      <ul class="why-list">
        <li class="why-item">
          <div class="why-item__icon">🚨</div>
          <div class="why-item__text">
            <h3>Emergency Leak Repair</h3>
            <p>Active leak in your West Jordan home? We dispatch a licensed contractor same day — no waiting until next week. Water damage spreads fast; we stop it at the source.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🌩️</div>
          <div class="why-item__text">
            <h3>Storm &amp; Hail Damage</h3>
            <p>After every major storm, West Jordan roofs take damage that isn't always visible from the ground. We inspect, document, and repair — with full insurance claim support built in.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🔍</div>
          <div class="why-item__text">
            <h3>Roof Inspections</h3>
            <p>Annual or pre-transaction inspections for West Jordan homeowners. We know which subdivision roof types are most likely to have issues and where to look first.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">📋</div>
          <div class="why-item__text">
            <h3>Insurance Claim Support</h3>
            <p>West Jordan homeowners are often dealing with the same insurers who cover thousands of claims after a storm. Proper documentation from the start gets your claim processed correctly.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Lead Form -->
  <section class="section" id="get-estimate">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Free Estimate</span>
        <h2>Get a West Jordan Roofer Out Fast — It's Free</h2>
        <p>Fill out the form and a licensed contractor serving West Jordan will follow up quickly.</p>
      </div>
      <LeadForm
        title="Request a Free Estimate in West Jordan, UT"
        subtitle="A licensed local roofing contractor will call you back — usually within the hour."
        elementId="westjordan-form"
      />
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>West Jordan Roof Emergency? Call Now.</h2>
      <p>Same-day response available throughout West Jordan and Salt Lake County.</p>
      <div class="cta-strip__actions">
        <a href={phoneHref} class="btn btn--accent btn--lg">📞 {phone} — Available 24/7</a>
      </div>
    </div>
  </section>

</BaseLayout>
