---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";

const cities = [
  {
    name: "Sandy",
    state: "UT",
    desc: "Home base. From the Dimple Dell area off 1300 East to the Quarry Bend neighborhoods near 9800 South — if you're in Sandy with a roof problem, someone can be out today.",
    zip: "84070",
  },
  {
    name: "Draper",
    state: "UT",
    desc: "Draper gets hit hard by summer hail. The Suncrest and south-facing foothill homes see some of the worst UV wear in the county too. We cover all of Draper including newer builds off Bangerter.",
    zip: "84020",
  },
  {
    name: "South Jordan",
    state: "UT",
    desc: "New construction doesn't mean storm-proof. Flashing failures are common in the first few years, and Daybreak takes a beating in July hail. We cover all of South Jordan.",
    zip: "84009",
  },
  {
    name: "Murray",
    state: "UT",
    desc: "A lot of Murray's housing stock is mid-century — which means roofs that are overdue. We serve all of Murray, from the State Street corridor east toward the foothills.",
    zip: "84107",
  },
  {
    name: "Midvale",
    state: "UT",
    desc: "Midvale has a mix of older and newer homes and both take storm damage the same way. We cover the full 84047 zip with the same response time as anywhere else on this list.",
    zip: "84047",
  },
  {
    name: "West Jordan",
    state: "UT",
    desc: "West Jordan is big — we cover all of it. Established neighborhoods along 7800 South and the newer developments going up near the Mountain View Corridor.",
    zip: "84084",
  },
  {
    name: "Salt Lake City",
    state: "UT",
    desc: "From the Avenues to Sugar House, Rose Park to the 9th & 9th area — SLC has some of the oldest roofing stock in the county. We connect you with someone who knows these neighborhoods.",
    zip: "84101",
  },
];
---

<BaseLayout
  title="Service Area | Sandy Roofing Pros — Sandy, UT"
  description="Sandy Roofing Pros serves Sandy, Draper, South Jordan, Murray, Midvale, West Jordan, and Salt Lake City. Emergency roof repair across all of Salt Lake County, Utah."
  canonicalUrl="/service-area"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <h1>Roofing Service Area — Salt Lake County, Utah</h1>
      <p>
        If your roof is leaking and you're anywhere from Midvale to Draper,
        there's a local roofer nearby who can get out today. Here's exactly where we cover.
      </p>
    </div>
  </section>

  <!-- Cities Grid -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Coverage Area</span>
        <h2>Cities We Serve</h2>
        <p>
          We cover these cities throughout Salt Lake County. Not on the list?
          Call anyway — we can often still find someone nearby.
        </p>
      </div>

      <div class="city-grid">
        {cities.map((city) => (
          <div class="city-card">
            <h3>{city.name}, {city.state} <span style="font-weight:400; color:#94A3B8; font-size:0.85rem;">{city.zip}</span></h3>
            <p>{city.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Local Matters -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Why It Matters</span>
        <h2>Utah Weather Is Hard on Roofs. Local Roofers Know Why.</h2>
        <p>
          The guys fixing roofs in this valley have been through Utah winters. They know
          what snowpack does to a low-slope section and what a July hailstorm looks like
          an hour after it passes. That's not something you learn from a manual.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__icon">❄️</div>
          <h3>Snow Load &amp; Ice Dams</h3>
          <p>
            Sandy sits at 4,500 feet and gets hammered in big snow years.
            Pack builds up on low-slope sections and at the eaves — that's where
            ice dams form, and that's where leaks start in February and March
            when you least want to deal with them.
          </p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">⛈️</div>
          <h3>Summer Hail</h3>
          <p>
            July and August are the worst for hail in the Salt Lake Valley.
            The damage doesn't always look like much from the street.
            From the roof, you can see the bruising and granule loss — that's
            five years off your shingle life in one afternoon.
          </p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">☀️</div>
          <h3>UV at Elevation</h3>
          <p>
            Higher elevation means more UV than you'd get at sea level.
            South-facing slopes bake in summer. Shingles crack and curl ahead
            of schedule — homeowners wonder why they're replacing a 25-year roof
            at year 18. This is why.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-strip">
    <div class="container">
      <h2>In Salt Lake County? We Can Get Someone Out.</h2>
      <p>
        Call now or fill out the form below. Free estimate, no obligation.
        A local roofer will follow up fast.
      </p>
      <div class="cta-strip__actions">
        <a href={phoneHref} class="btn btn--accent btn--lg">
          📞 {phone}
        </a>
        <a href="#contact-form" class="btn btn--outline btn--lg">
          Submit a Request
        </a>
      </div>
    </div>
  </section>

  <!-- Lead Form -->
  <section class="section section--alt" id="contact-form">
    <div class="container">
      <LeadForm
        title="Request Roofing Help in Your Area"
        subtitle="Tell us your city and describe your roof issue — we'll get you connected fast."
      />
    </div>
  </section>

</BaseLayout>
