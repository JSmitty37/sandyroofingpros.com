---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';

const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";
---

<BaseLayout
  title="Home | Sandy Roofing Pros — Sandy, UT"
  description="24/7 emergency roof leak repair and storm damage restoration in Sandy, Utah and Salt Lake County. Call now for a free estimate from a licensed local contractor."
  canonicalUrl="/"
>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container">
      <span class="hero__badge">⚡ Available 24 Hours a Day, 7 Days a Week</span>

      {/* HEADLINE OPTION A — active */}
      <h1>Leaking Roof in Sandy? We'll Get Someone There Today.</h1>

      {/* HEADLINE OPTION B — swap in if you prefer this one
      <h1>Sandy Homeowners: When Your Roof Goes, You Need Help Now.</h1>
      */}

      <p class="hero__sub">
        Water coming in doesn't wait for business hours. We connect Salt Lake County homeowners
        with local roofers who actually answer the phone — day or night. Free estimate, no runaround.
      </p>
      <div class="hero__ctas">
        <a href={phoneHref} class="btn btn--primary btn--lg">
          📞 Call Now for a Free Estimate
        </a>
        <a href="#get-estimate" class="btn btn--outline btn--lg">
          Get Instant Help Online
        </a>
      </div>
    </div>
  </section>

  <!-- ===== TRUST BAR ===== -->
  <div class="trust-bar">
    <div class="container">
      <ul class="trust-bar__list">
        <li class="trust-bar__item">
          <span class="trust-bar__icon">⚡</span>
          <span>Same-Day Response</span>
        </li>
        <li class="trust-bar__item">
          <span class="trust-bar__icon">✅</span>
          <span>Licensed Local Contractors</span>
        </li>
        <li class="trust-bar__item">
          <span class="trust-bar__icon">💲</span>
          <span>Free Estimates</span>
        </li>
        <li class="trust-bar__item">
          <span class="trust-bar__icon">🛡️</span>
          <span>Insurance Claims Assisted</span>
        </li>
        <li class="trust-bar__item">
          <span class="trust-bar__icon">📍</span>
          <span>Sandy &amp; Salt Lake County</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- ===== SERVICES ===== -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">What We Do</span>
        <h2>Roofing Help for Sandy &amp; Salt Lake County</h2>
        <p>
          Active leak, storm aftermath, or just a roof that hasn't been looked at in years —
          we'll get the right person out to you fast.
        </p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-card__icon">🚨</div>
          <h3>Emergency Roof Leak Repair</h3>
          <p>
            Water coming in right now? Stop reading and call. A roofer can be at your door
            the same day — before that wet spot on your ceiling becomes a ruined joist
            or a mold problem.
          </p>
          <a href="/services#emergency-leak" class="btn btn--primary">Learn More</a>
        </div>

        <div class="service-card">
          <div class="service-card__icon">🌩️</div>
          <h3>Storm Damage Roof Repair</h3>
          <p>
            Hail hit your neighborhood? Wind stripped shingles before you even got home?
            Utah storms move fast and insurance windows don't stay open forever.
            Get an inspection on the books now.
          </p>
          <a href="/services#storm-damage" class="btn btn--primary">Learn More</a>
        </div>

        <div class="service-card">
          <div class="service-card__icon">🔍</div>
          <h3>Roof Inspections</h3>
          <p>
            The cheapest repair is the one you catch before it becomes a leak. Get a roofer
            up there before the snow flies — not after your first water stain appears
            in February.
          </p>
          <a href="/services#roof-inspection" class="btn btn--primary">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE US ===== -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Why Sandy Roofing Pros</span>
        <h2>Someone Answers. Someone Shows Up.</h2>
        <p>
          That's a low bar — but it's one a lot of roofing companies can't clear
          when you call at 9 p.m. with water coming through your ceiling.
        </p>
      </div>

      <ul class="why-list">
        <li class="why-item">
          <div class="why-item__icon">⚡</div>
          <div class="why-item__text">
            <h3>Someone Picks Up the Phone</h3>
            <p>Not a voicemail, not a contact form. We route you to a local roofer who can actually talk through your situation and get out same day.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">✅</div>
          <div class="why-item__text">
            <h3>Licensed in Utah</h3>
            <p>Every contractor we work with holds a Utah license. You get someone who knows the state's building codes and can back up their work.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">💲</div>
          <div class="why-item__text">
            <h3>Written Estimate Before Anything Starts</h3>
            <p>You'll know the number before they touch the roof. No surprises on the invoice, no pressure to decide on the spot.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">📋</div>
          <div class="why-item__text">
            <h3>Insurance Documentation Done Right</h3>
            <p>Storm damage claims require specific photos, measurements, and written reports. Our roofers know what adjusters look for and document it correctly the first time.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">🛠️</div>
          <div class="why-item__text">
            <h3>Emergency Tarping — Same Day</h3>
            <p>If the repair can't happen immediately, a tarp goes on. Stops the bleeding while a permanent fix gets scheduled.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-item__icon">📍</div>
          <div class="why-item__text">
            <h3>Minutes Away, Not Hours</h3>
            <p>Sandy, Draper, South Jordan, Murray, Midvale, West Jordan, Salt Lake City — these aren't territories. These are neighborhoods the roofers we work with drive through every day.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ===== SERVICE AREA SNIPPET ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="section-heading text-center">
        <span class="section-heading__eyebrow" style="color:#F59E0B;">Where We Serve</span>
        <h2>Roofing Help Across Salt Lake County</h2>
        <p style="color:#94A3B8;">
          If you're within 20 miles of Sandy — you're covered. From 9000 South
          to the Avenues, we've got someone nearby who can get out today.
        </p>
      </div>

      <div class="area-grid">
        <div class="area-card">
          <div class="area-card__city">Sandy</div>
          <div class="area-card__state">Salt Lake County, UT</div>
        </div>
        <div class="area-card">
          <div class="area-card__city">Draper</div>
          <div class="area-card__state">Salt Lake County, UT</div>
        </div>
        <div class="area-card">
          <div class="area-card__city">South Jordan</div>
          <div class="area-card__state">Salt Lake County, UT</div>
        </div>
        <div class="area-card">
          <div class="area-card__city">Murray</div>
          <div class="area-card__state">Salt Lake County, UT</div>
        </div>
        <div class="area-card">
          <div class="area-card__city">Midvale</div>
          <div class="area-card__state">Salt Lake County, UT</div>
        </div>
        <div class="area-card">
          <div class="area-card__city">West Jordan</div>
          <div class="area-card__state">Salt Lake County, UT</div>
        </div>
        <div class="area-card">
          <div class="area-card__city">Salt Lake City</div>
          <div class="area-card__state">Salt Lake County, UT</div>
        </div>
      </div>

      <div class="text-center" style="margin-top:2rem;">
        <a href="/service-area" class="btn btn--outline">See Full Service Area</a>
      </div>
    </div>
  </section>

  <!-- ===== LEAD FORM ===== -->
  <section class="section section--alt" id="get-estimate">
    <div class="container">
      <div class="section-heading">
        <span class="section-heading__eyebrow">Free Estimate</span>
        <h2>Tell Us What's Going On — We'll Take It From There</h2>
        <p>
          Fill out the form and a local roofer will call you back fast.
          Not hours. Not tomorrow. Fast.
        </p>
      </div>

      <LeadForm
        title="Get a Free Roof Estimate"
        subtitle="A local Salt Lake County roofer will call you — usually within the hour."
      />
    </div>
  </section>

  <!-- ===== FINAL CTA STRIP ===== -->
  <section class="cta-strip">
    <div class="container">
      <h2>Roof Leaking Right Now? Call — Don't Google.</h2>
      <p>
        A slow drip in October becomes a ruined ceiling by February.
        We'll get someone to your door today.
      </p>
      <div class="cta-strip__actions">
        <a href={phoneHref} class="btn btn--accent btn--lg">
          📞 {phone} — Call Now
        </a>
        <a href="#get-estimate" class="btn btn--outline btn--lg">
          Submit a Request Online
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
