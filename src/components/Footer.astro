---
const phone = "(801) 514-7004";
const phoneHref = "tel:+18015147004";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">

    <div class="footer-grid">
      <div>
        <span class="footer-brand">Sandy Roofing Pros</span>
        <p class="footer-tagline">24/7 Emergency Roofing — Sandy, Utah &amp; Salt Lake County</p>
        <a href={phoneHref} class="footer-phone">{phone}</a>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul class="footer-links">
          <li><a href="/services#emergency-leak">Emergency Leak Repair</a></li>
          <li><a href="/services#storm-damage">Storm Damage Repair</a></li>
          <li><a href="/services#roof-inspection">Roof Inspections</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/service-area">Service Area</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </div>
    </div>

    <hr class="footer-divider" />

    <div class="footer-bottom">
      <p class="footer-disclaimer">
        <strong style="color:#64748B">Disclaimer:</strong> Sandy Roofing Pros is an independent third-party lead generation service. We connect homeowners with licensed, local roofing contractors in Salt Lake County. We do not perform roofing work ourselves. All roofing services are provided by independently licensed contractors.
      </p>
    </div>

    <p class="footer-copy" style="margin-top:1rem;">
      &copy; {year} Sandy Roofing Pros. All rights reserved.
    </p>

  </div>
</footer>
